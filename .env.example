# Copy this file to `.env` in the same directory (repo root). `.env` is gitignored.
#
# Cursor Cloud Agents API key (for Feature Start → launch cloud agent):
#   https://cursor.com/dashboard/cloud-agents
#   Create an API key there and paste it below. This is NOT the same as “being logged into Cursor”
#   in the app — it is a separate credential for the HTTP API.
#
CURSOR_API_KEY=

# Optional: public base URL of this orchestrator (e.g. ngrok) so a cloud agent can POST activity.
# ORCHESTRATOR_ACTIVITY_BASE_URL=

# Optional: require x-api-key on /api/* when set.
# ORCHESTRATOR_API_KEY=
